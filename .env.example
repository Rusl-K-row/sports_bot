# =============================================================================
# SPORTS BETTING ANALYTICS BOT - НАСТРОЙКИ ОКРУЖЕНИЯ
# =============================================================================
# Скопируй этот файл в .env и заполни своими значениями
# НИКОГДА НЕ КОММИТИ .env ФАЙЛ В ГИТ!
# =============================================================================

# =============================================================================
# TELEGRAM BOT
# =============================================================================
# Получи токен у @BotFather в Telegram
BOT_TOKEN=your_telegram_bot_token_here

# =============================================================================
# API-FOOTBALL.COM (Платный, но самый надежный для футбола)
# https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io

# =============================================================================
# FOOTBALL-DATA.ORG (Бесплатный с лимитами)
# https://www.football-data.org/
FOOTBALL_DATA_KEY=your_football_data_key_here

# =============================================================================
# THE SPORTS DATABASE (Бесплатный)
# https://www.thesportsdb.com/
THESPORTSDB_KEY=your_thesportsdb_key_here

# =============================================================================
# ESPN (Опционально, если есть доступ)
# Требует специального доступа
ESPN_API_KEY=your_espn_api_key_here

# =============================================================================
# МАШИННОЕ ОБУЧЕНИЕ
# =============================================================================
# Путь к сохраненной модели (будет создан автоматически)
MODEL_PATH=./models/match_model.joblib

# Переобучение модели (в часах)
MODEL_RETRAIN_INTERVAL_HOURS=24

# Минимум образцов для переобучения модели
MIN_SAMPLES_FOR_TRAINING=100

# Порог уверенности для принятия решения о прогнозе
PREDICTION_CONFIDENCE_THRESHOLD=0.6

# =============================================================================
# KEŠИРОВАНИЕ (Для уменьшения количества запросов к API)
# =============================================================================
# Время жизни кеша в секундах (1 час = 3600 секунд)
CACHE_TTL=3600

# =============================================================================
# НАСТРОЙКИ VALUE BETTING
# =============================================================================
# Минимальное преимущество для consideration как value bet (в долях)
# 0.05 = 5% преимущество над линией букмекера
VALUE_BET_THRESHOLD=0.05

# Минимальный и максимальный коэффициенты для рассмотрения
MIN_ODDS=1.5
MAX_ODDS=5.0

# =============================================================================
# УВЕДОМЛЕНИЯ
# =============================================================================
# Уведомлять о найденных value bets
NOTIFY_ON_VALUE_BET=true

# Уведомлять о высокой уверенности в прогнозах
NOTIFY_ON_HIGH_CONFIDENCE=true

# Порог высокой уверенности (в долях от 0 до 1)
HIGH_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# ОПЦИОНАЛЬНЫЕ ИНТЕГРАЦИИ
# =============================================================================
# Включить веб-дашборд для мониторинга (требует дополнительной настройки)
ENABLE_WEB_DASHBOARD=false

# Включить email уведомления о важных событиях
ENABLE_EMAIL_ALERTS=false

# Настройки для email (если ENABLE_EMAIL_ALERTS=true)
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_email_app_password
# EMAIL_TO=recipient@example.com

# =============================================================================
# GITHUB ИНТЕГРАЦИЯ (Для управления репозиторием от твоего имени)
# =============================================================================
# Получи Personal Access Token в настройках GitHub → Developer settings
GITHUB_TOKEN=your_github_personal_access_token_here

# URL репозитория для бэкапа и управления проектами
# Формат: https://github.com/username/repository.git
GITHUB_REPO_URL=https://github.com/your_username/your_repo_name.git

# =============================================================================
# ДРУГИЕ НАСТРОЙКИ
# =============================================================================
# Название бота (отображается в интерфейсе)
BOT_NAME=SportAnalyticsBot

# Версия бота
BOT_VERSION=1.0.0

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# ВАЖНОЕ ПРЕДУПРЕЖДЕНИЕ:
# Этот бот предназначен ТОЛЬКО для образовательных и аналитических целей.
# Ставки на спорт связаны с риском финансовых потерь.
# Используй информацию бота ответственно и только на свой страх и риск.
# Не ставь больше, чем можешь позволить себе потерять.
# Обращайся к профессионалам, если у тебя есть проблемы с азартными играми.
