# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=your_api_football_key
API_FOOTBALL_HOST=v3.football.api-sports.io

# Football-Data.org (https://www.football-data.org/)
FOOTBALL_DATA_KEY=your_football_data_key

# Опционально: другие источники
# THE_SPORTS_DB_KEY=...
# ESPN_API_KEY=...

# ML & кеш
MODEL_PATH=./data/model.joblib

# Голосовые сервисы (опционально)
# Для STT: например, локальный Whisper
WHISPER_MODEL=base  # или tiny, small, medium, large
# Для TTS: например, Edge TTS (бесплатен) или ElevenLabs
TTS_PROVIDER=edge  # options: edge, elevenlabs, pyttsx3
ELEVENLABS_KEY=your_elevenlabs_key_here  # если используешь ElevenLabs